# Copie para .env na raiz do projeto:  copy deploy\.env.example .env
# Gere senhas:  powershell -File scripts\generate-deploy-env.ps1

# Domínio público (ex: memorycard.seudominio.com.br)
DOMAIN=seudominio.com.br

# Senhas — NÃO use os exemplos em produção
POSTGRES_PASSWORD=
JWT_SECRET=

# E-mail opcional para HTTPS automático (Let's Encrypt via Caddy)
ACME_EMAIL=voce@email.com
